#!/bin/bash

# CI Local Runner - Run the same checks as GitHub Actions locally

set -e

echo "🚀 Running CI checks locally..."
echo "================================"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to print colored output
print_status() {
    if [ $2 -eq 0 ]; then
        echo -e "${GREEN}✅ $1${NC}"
    else
        echo -e "${RED}❌ $1${NC}"
        return 1
    fi
}

# Check if we're in the right directory
if [ ! -f "Gemfile" ]; then
    echo -e "${RED}❌ Please run this script from the Rails project root directory${NC}"
    exit 1
fi

# Check if required services are running
echo -e "${YELLOW}🔍 Checking services...${NC}"

# Check PostgreSQL
if ! pg_isready -q; then
    echo -e "${RED}❌ PostgreSQL is not running. Please start it first.${NC}"
    echo "   On macOS: brew services start postgresql"
    echo "   On Ubuntu: sudo service postgresql start"
    exit 1
fi

# Check Redis
if ! redis-cli ping > /dev/null 2>&1; then
    echo -e "${RED}❌ Redis is not running. Please start it first.${NC}"
    echo "   On macOS: brew services start redis"
    echo "   On Ubuntu: sudo service redis-server start"
    exit 1
fi

print_status "PostgreSQL is running" 0
print_status "Redis is running" 0

# Set up environment
export RAILS_ENV=test
export DATABASE_URL=postgres://postgres:postgres@localhost:5432/social_app_test
export REDIS_URL=redis://localhost:6379/0

echo ""
echo -e "${YELLOW}🔧 Setting up database...${NC}"
bundle exec rails db:create RAILS_ENV=test
bundle exec rails db:schema:load RAILS_ENV=test
print_status "Database setup complete" 0

echo ""
echo -e "${YELLOW}🧹 Running RuboCop...${NC}"
if bundle exec rubocop; then
    print_status "RuboCop passed" 0
else
    print_status "RuboCop failed" 1
    exit 1
fi

echo ""
echo -e "${YELLOW}🧪 Running RSpec tests...${NC}"
if bundle exec rspec --format progress; then
    print_status "RSpec tests passed" 0
else
    print_status "RSpec tests failed" 1
    exit 1
fi

echo ""
echo -e "${YELLOW}📊 Running RSpec with coverage...${NC}"
export COVERAGE=true
if bundle exec rspec --format progress; then
    print_status "Coverage report generated" 0
    echo -e "${GREEN}📈 Coverage report available at: coverage/index.html${NC}"
else
    print_status "Coverage generation failed" 1
    exit 1
fi

echo ""
echo -e "${YELLOW}🔒 Running security checks...${NC}"

# Brakeman
if command -v brakeman > /dev/null 2>&1; then
    if brakeman --no-pager; then
        print_status "Brakeman security scan passed" 0
    else
        print_status "Brakeman found security issues" 1
        exit 1
    fi
else
    echo -e "${YELLOW}⚠️  Brakeman not installed. Install with: gem install brakeman${NC}"
fi

# Bundle Audit
if command -v bundle-audit > /dev/null 2>&1; then
    if bundle audit --update; then
        print_status "Bundle audit passed" 0
    else
        print_status "Bundle audit found vulnerabilities" 1
        exit 1
    fi
else
    echo -e "${YELLOW}⚠️  Bundle audit not installed. Install with: gem install bundler-audit${NC}"
fi

echo ""
echo -e "${YELLOW}🔍 Checking for debug statements...${NC}"
DEBUG_COUNT=$(grep -r "puts\|p\|binding.pry\|debugger" app/ lib/ --include="*.rb" 2>/dev/null | wc -l)
if [ $DEBUG_COUNT -gt 0 ]; then
    echo -e "${RED}❌ Found $DEBUG_COUNT debug statements:${NC}"
    grep -r "puts\|p\|binding.pry\|debugger" app/ lib/ --include="*.rb" 2>/dev/null
    echo ""
    echo -e "${RED}Please remove debug statements before committing.${NC}"
    exit 1
else
    print_status "No debug statements found" 0
fi

echo ""
echo -e "${YELLOW}📝 Checking for TODO/FIXME comments...${NC}"
TODO_COUNT=$(grep -r "TODO\|FIXME" app/ lib/ spec/ --include="*.rb" 2>/dev/null | wc -l)
if [ $TODO_COUNT -gt 0 ]; then
    echo -e "${YELLOW}⚠️  Found $TODO_COUNT TODO/FIXME comments:${NC}"
    grep -r "TODO\|FIXME" app/ lib/ spec/ --include="*.rb" 2>/dev/null
    echo ""
    echo -e "${YELLOW}Consider addressing these before merging.${NC}"
else
    print_status "No TODO/FIXME comments found" 0
fi

echo ""
echo -e "${GREEN}🎉 All CI checks passed!${NC}"
echo -e "${GREEN}Your code is ready for commit and push.${NC}"
